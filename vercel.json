{
    "version": 2,
    "installCommand": "cd client && pnpm install",
    "buildCommand": "cd client && pnpm build",
    "outputDirectory": "client/dist",
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/app.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/client/dist/$1"
        }
    ]
}
